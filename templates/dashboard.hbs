<div class="da-dash">
  {{#if hasScene}}
  <div class="da-dash-top">
    <span class="da-dash-scene">{{localize "DAT.Dash.Scene"}}: <b>{{sceneName}}</b> · {{floorCount}} {{localize "DAT.Dash.Floors"}}</span>
    <span class="da-dash-spacer"></span>
    <button type="button" class="da-dash-btn" data-action="importFolder"><i class="fa-solid fa-file-import"></i> {{localize "DAT.Controls.Import"}}</button>
    <button type="button" class="da-dash-btn" data-action="addStairs"><i class="fa-solid fa-stairs"></i> {{localize "DAT.Controls.AddStairs"}}</button>
  </div>
  <div class="da-dash-body">
    <div class="da-dash-floors">
      <div class="da-dash-hd">{{localize "DAT.Dash.FloorsHd"}}</div>
      {{#each floors}}
      <div class="da-floor-row{{#if this.active}} active{{/if}}" data-action="viewFloor" data-level-id="{{this.id}}">
        <span class="da-floor-thumb" data-src="{{this.src}}"></span>
        <div class="da-floor-meta">
          <div class="da-floor-name">{{this.name}}{{#if this.start}} <span class="da-star">★</span>{{/if}}</div>
          <div class="da-floor-elev">{{localize "DAT.Dash.Elev"}} {{this.bottom}}–{{this.top}}{{#if this.active}} · {{localize "DAT.Dash.Viewing"}}{{/if}}</div>
        </div>
      </div>
      {{/each}}
      <button type="button" class="da-floor-add" data-action="addFloor" data-tooltip="{{localize "DAT.Dash.AddFloorHint"}}"><i class="fa-solid fa-plus"></i> {{localize "DAT.Dash.AddFloor"}}</button>
    </div>
    <div class="da-dash-detail">
      <div class="da-floor-edit">
        <div class="da-edit-row">
          <input type="text" class="da-edit-name" value="{{selected.name}}" placeholder="{{localize "DAT.Dash.NamePlaceholder"}}" />
          <button type="button" class="da-edit-star{{#if selected.start}} is-start{{/if}}" data-action="setStart" data-tooltip="{{localize "DAT.Dash.SetStartHint"}}">{{#if selected.start}}★{{else}}☆{{/if}}</button>
        </div>
        <div class="da-edit-row">
          <label class="da-edit-lbl">{{localize "DAT.Dash.Elev"}}</label>
          <input type="number" class="da-edit-bottom" value="{{selected.bottom}}" step="1" />
          <span class="da-edit-dash">–</span>
          <input type="number" class="da-edit-top" value="{{selected.top}}" step="1" />
          <span class="da-dash-spacer"></span>
          <button type="button" class="da-edit-move" data-action="moveDown" data-tooltip="{{localize "DAT.Dash.MoveDown"}}"{{#unless selected.canDown}} disabled{{/unless}}><i class="fa-solid fa-arrow-down"></i></button>
          <button type="button" class="da-edit-move" data-action="moveUp" data-tooltip="{{localize "DAT.Dash.MoveUp"}}"{{#unless selected.canUp}} disabled{{/unless}}><i class="fa-solid fa-arrow-up"></i></button>
        </div>
        <div class="da-edit-row da-edit-actions">
          <button type="button" class="da-dash-btn" data-action="saveFloor"><i class="fa-solid fa-check"></i> {{localize "DAT.Dash.SaveFloor"}}</button>
          <button type="button" class="da-dash-btn" data-action="replaceImage" data-tooltip="{{localize "DAT.Dash.ReplaceImageHint"}}"><i class="fa-solid fa-image"></i> {{localize "DAT.Dash.ReplaceImage"}}</button>
          <span class="da-dash-spacer"></span>
          <button type="button" class="da-edit-danger" data-action="removeFloor" data-tooltip="{{localize "DAT.Dash.RemoveFloorHint"}}"><i class="fa-solid fa-trash"></i> {{localize "DAT.Dash.RemoveFloor"}}</button>
        </div>
        <div class="da-edit-row da-edit-actions">
          <span class="da-dash-spacer"></span>
          <button type="button" class="da-edit-link" data-action="openNative" data-tooltip="{{localize "DAT.Dash.OpenNativeHint"}}">{{localize "DAT.Dash.OpenNative"}}</button>
        </div>
      </div>
      <div class="da-dash-hd">{{localize "DAT.Dash.StairsHd"}}</div>
      {{#if selected.stairs.length}}
        {{#each selected.stairs}}
        <div class="da-dash-stair">
          <span class="da-dash-stair-ic da-stairs-mode--{{this.mode}}">{{this.icon}}</span>
          <div class="da-dash-stair-text">
            <span class="da-dash-stair-label">{{this.label}}</span>
            <span class="da-stairs-mode da-stairs-mode--{{this.mode}}">{{this.mode}}</span>
            <div class="da-dash-stair-sub">{{this.sub}}</div>
          </div>
        </div>
        {{/each}}
      {{else}}
        <p class="da-dash-empty">{{localize "DAT.Dash.NoStairs"}}</p>
      {{/if}}
    </div>
  </div>
  {{else}}
  <p class="da-dash-empty">{{localize "DAT.Dash.NoScene"}}</p>
  {{/if}}
</div>
